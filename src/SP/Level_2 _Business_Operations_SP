-- =============================================
-- SP_PurchaseOrders_Close - بستن سفارش خرید
-- اعتبارسنجی وجود سفارش + چک وضعیت Completed/Cancelled
-- =============================================
create or alter proc SP_PurchaseOrders_Close
@PurchaseOrderID int
as begin
	set nocount on
	begin try
		begin tran
				if not exists (select 1 from prc.PurchaseOrders where PurchaseOrderID = @PurchaseOrderID)
				begin
					select 'شماره سفارش خرید وارد شده نامعتبر است' as err
					rollback
					return
				end
				declare @Status nvarchar(20) = (select Status from prc.PurchaseOrders where PurchaseOrderID = @PurchaseOrderID )

				if @Status = 'Completed'
				begin
					select 'این سفارش از قبل بسته شده است' as err
					rollback
					return
				end
				if @Status = 'Cancelled'
				begin
					select 'سفارش لغو شده را نمیتوان بست' as err
					rollback
					return
				end
				update prc.PurchaseOrders set Status = 'Completed' where PurchaseOrderID = @PurchaseOrderID 
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end
