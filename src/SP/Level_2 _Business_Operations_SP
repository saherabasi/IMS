-- =============================================
-- SP_AdjustStock - اصلاح موجودی (انبارگردانی)
-- اعتبارسنجی محصول، انبار و وجود کالا در انبار
-- جایگزینی موجودی با عدد جدید
-- =============================================
create proc SP_AdjustStock
@ProductID int,
@WarehouseID int,
@NewQuantity int
as begin
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from inv.Products where ProductID = @ProductID)
			begin
				select 'محصول وارد شده نامعتبر است' as err
				rollback
				return
			end
			if not exists (select 1 from inv.Warehouses where WarehouseID = @WarehouseID)
			begin
				select 'انبار وارد شده نامعتبر است' as err
				rollback
				return
			end
			if not exists (select 1 from inv.Stocks where WarehouseID = @WarehouseID and ProductID = @ProductID)
			begin
				select 'انبار وارد شده همچین محصولی نداره' as err
				rollback
				return
			end
			update inv.Stocks set Quantity = @NewQuantity where WarehouseID = @WarehouseID and ProductID = @ProductID
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end
