-- =============================================
-- SP_TransferStock - انتقال موجودی بین دو انبار
-- اعتبارسنجی محصول، انبار مبدا و مقصد + موجودی کافی
-- در صورت نبود کالا در انبار مقصد، رکورد جدید ایجاد می‌شود
-- =============================================
create proc SP_TransferStock
@ProductID int,
@Quantity int,
@SrcWarehouseID int,
@DestWarehouseID int 
as begin
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from inv.Products where ProductID = @ProductID)
			begin
				select 'محصول وارد شده نامعتبر است' as err
				rollback
				return
			end
			if not exists (select 1 from inv.Warehouses where WarehouseID = @SrcWarehouseID)
			begin
				select 'انبار مبدا وارد شده نامعتبر است' as err
				rollback
				return
			end
			if not exists (select 1 from inv.Warehouses where WarehouseID = @DestWarehouseID)
			begin
				select 'انبار مقصدوارد شده نامعتبر است' as err
				rollback
				return
			end
			if not exists (select 1 from inv.Stocks where WarehouseID = @SrcWarehouseID and ProductID = @ProductID)
			begin
				select 'انبار مبدا همچین محصولی نداره' as err
				rollback
				return
			end
			declare @Stock int = (select Quantity from inv.Stocks where ProductID = @ProductID and WarehouseID = @SrcWarehouseID)
			if @Quantity > @Stock
			begin
				select 'موجودی کافی نمیباشد' as err
				rollback
				return
			end
			if not exists (select 1 from inv.Stocks where ProductID = @ProductID and WarehouseID = @DestWarehouseID)
			begin
				update inv.Stocks set Quantity -= @Quantity where ProductID = @ProductID and WarehouseID = @SrcWarehouseID
				
				insert into inv.Stocks (ProductID,WarehouseID,Quantity)
				values(@ProductID,@DestWarehouseID,@Quantity)
			end
			else
			begin
				update inv.Stocks set Quantity -= @Quantity where ProductID = @ProductID and WarehouseID = @SrcWarehouseID
				update inv.Stocks set Quantity += @Quantity where ProductID = @ProductID and WarehouseID = @DestWarehouseID
			end
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end
