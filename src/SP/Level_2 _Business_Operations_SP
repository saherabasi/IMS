-- =============================================
-- SP_ReturnProduct - مرجوعی کالا از فاکتور
-- اعتبارسنجی فاکتور، محصول و وجود محصول در فاکتور
-- برگشت موجودی به انبار مبدا
-- =============================================
create proc SP_ReturnProduct
@InvoiceID int,
@ProductID int,
@Quantity int
as begin
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from sls.Invoices where InvoiceID = @InvoiceID)
			begin
				select 'شماره فاکتور وارد شده نامعتبر است' as err
				rollback
				return
			end
			if not exists (select 1 from inv.Products where ProductID = @ProductID)
			begin
				select 'محصول وارد شده نامعتبر است' as err
				rollback
				return
			end
			if not exists(select 1 from sls.InvoiceDetails where InvoiceID = @InvoiceID and ProductID = @ProductID)
			begin
				select 'فاکتور وارد شده شامل همچین محصولی نمی باشد' as err
				rollback
				return
			end
			declare @WarehoseID int = (
			select so.SrcWarehouseID
			from sls.SalesOrders so
			inner join 
			sls.Invoices i on so.SalesOrderID = i.SalesOrderID
			where i.InvoiceID = @InvoiceID
			)
			update inv.Stocks set Quantity += @Quantity where WarehouseID = @WarehoseID and ProductID = @ProductID
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end
go
