-- =============================================
-- sp_UpdateStock - بروزرسانی موجودی انبار
-- پشتیبانی از افزایش و کاهش موجودی
-- اعتبارسنجی کالا، انبار و موجودی کافی
-- ثبت لاگ در StockLogs
-- =============================================
create or alter proc [dbo].[sp_UpdateStock]
@ProductID int,
@WarehouseID int,
@Quantity int
as begin
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from inv.stocks where ProductID = @ProductID)
			begin
				select 'محصول وارد شده وجود ندارد' as err
				rollback
				return
			end
			if not exists (select 1 from inv.stocks where WarehouseID = @WarehouseID)
			begin
				select 'انبار وارد شده معتبر نیست' as err
				rollback
				return
			end
			if @Quantity < 0
			begin
				declare @stock int = (select quantity from inv.Stocks where ProductID = @ProductID and WarehouseID = @WarehouseID)
				if @Quantity > @stock
					begin
						select 'موجودی کافی نمیباشد' as err
						rollback
						return
					end
			end
			update inv.Stocks set Quantity = Quantity + @Quantity
			where ProductID = @ProductID and WarehouseID = @WarehouseID
			declare @NewStock int = (select quantity from inv.Stocks where ProductID = @ProductID and WarehouseID = @WarehouseID)

			insert into log.StockLogs(ProductID,WarehouseID,OldQuantity,NewQuantity,ChangeQuantity,Reason,UserID,ChangeDate)
			values(@ProductID,@WarehouseID,@stock,@NewStock,(@NewStock-@stock),null,null,getdate())
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end
GO

