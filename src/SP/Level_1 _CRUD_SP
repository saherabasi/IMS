-- =============================================
-- SP_Customer_Add - ثبت مشتری جدید
-- اعتبارسنجی تکراری نبودن شماره تماس و کد ملی
-- ثبت لاگ در CustomerLog
-- =============================================
create or alter proc [dbo].[SP_Customer_Add]
@FirstName nvarchar(30),
@LastName nvarchar(30),
@PhoneNumber nvarchar(30),
@NationalCode nvarchar(15),
@CustomerTypeID int = 0,
@Address nvarchar(100)
as begin
	set nocount on
	begin try
		begin tran
			if exists (select 1 from sls.Customers where PhoneNumber = @PhoneNumber)
			begin
				select 'شماره تلفن وارد شده از قبل وجود دارد' as err
				rollback
				return
			end
			if exists (select 1 from sls.Customers where NationalCode = @NationalCode)
			begin
				select 'کد ملی وارد شده از قبل وجود دارد' as err
				rollback
				return
			end
			if not exists (select 1 from sls.CustomerTypes where CustomerTypeID = @CustomerTypeID)
			begin
				select 'نوع مشتری وارد شده معتبر نمی باشد' as err
				rollback
				return
			end
			insert into sls.Customers (FirstName,LastName,PhoneNumber,NationalCode,
			CustomerTypeID,Address,registerDate)
			values (@FirstName,@LastName,@PhoneNumber,@NationalCode,
			@CustomerTypeID,@Address,GETDATE())

			insert into sls.CustomerLog(CustomerID,FirstName,LastName,PhoneNumber,NationalCode,CustomerTypeID,Address,ActionType,CreateDate)
			values(SCOPE_IDENTITY(),@FirstName,@LastName,@PhoneNumber,@NationalCode,@CustomerTypeID,@Address,'Insert',GETDATE())

			select SCOPE_IDENTITY() as NewCustomerID , 'ثبت کاربر با موفقیت انجام شد' as status
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end
GO

-- =============================================
-- SP_Product_Add - ثبت کالای جدید
-- اعتبارسنجی تکراری نبودن کد کالا و معتبر بودن دسته/برند/واحد
-- ثبت لاگ در ProductLog
-- =============================================
create or alter  proc [dbo].[SP_Product_Add]
@ProductCode nvarchar(20),
@ProductName nvarchar(50),
@CategoryID int,
@BrandID int,
@UnitID int,
@Barcode nvarchar(60),
@Description nvarchar(100)
as begin
	set nocount on
	begin try
		begin tran
			if exists (select 1 from inv.Products where ProductCode = @ProductCode)
			begin
				select 'کد محصول وارد شده از قبل وجود دارد' as err
				rollback
				return
			end
			if @CategoryID is not null and not exists (select 1 from inv.Categories where CategoryID = @CategoryID)
			begin
				select 'دسته بندی انتخاب شده معتبر نیست' as err
				rollback
				return
			end
			if @BrandID is not null and not exists (select 1 from inv.Brands where BrandID = @BrandID)
			begin
				select 'برند انتخاب شده معتبر نیست' as err
				rollback
				return
			end
			if @UnitID is not null and not exists (select 1 from inv.Units  where UnitID = @UnitID)
			begin
				select 'واحد انتخاب شده معتبر نیست' as err
				rollback
				return
			end

			insert into inv.Products (ProductCode,ProductName,CategoryID
			,BrandID,UnitID,Barcode,Description,IsActive,CreateDate)
			values(@ProductCode,@ProductName,@CategoryID,@BrandID,@UnitID
			,@Barcode,@Description,default,getdate())

			insert into inv.ProductLog(ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,Description,IsActive,ActionType,CreateDate)
			values(SCOPE_IDENTITY(),@ProductCode,@ProductName,@CategoryID,@BrandID,@UnitID,@Barcode,@Description,default,'Insert',getdate())

			select SCOPE_IDENTITY() as ProductID , 'محصول با موفقیت وارد شد' as status
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end

GO

-- =============================================
-- SP_Product_Del - غیرفعال کردن کالا
-- اعتبارسنجی وجود کالا و فعال بودن آن
-- ثبت لاگ در ProductLog با ActionType = 'Delete'
-- =============================================
create or alter  proc [dbo].[SP_Product_Del]
@ProductID int
as begin
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from inv.Products where ProductID = @ProductID)
			begin
				select 'شناسه وارد شده وجود ندارد' as err
				rollback
				return
			end
			if exists (select 1 from inv.Products where ProductID = @ProductID and IsActive = 0)
			begin
				select 'کالا از قبل حذف شده' as err
				rollback
				return
			end
			update inv.Products set IsActive = 0 where ProductID = @ProductID

			declare @ProductCode nvarchar(20),@ProductName nvarchar(50),@CategoryID int,@BrandID int,@UnitID int,@Barcode nvarchar(50)

			select @ProductCode = p.ProductCode,@ProductName = p.ProductName,@CategoryID = p.CategoryID,@BrandID =p.BrandID ,@UnitID = p.UnitID,@Barcode = p.Barcode
			from inv.Products p where ProductID = @ProductID

			insert into inv.ProductLog(ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,Description,IsActive,ActionType,CreateDate)
			values(@ProductID,@ProductCode,@ProductName,@CategoryID,@BrandID,@UnitID,@Barcode,'حذف محصول',0,'Delete',getdate())
			
			select @ProductID as ProductID , 'محصول با موفقیت حذف شد' as status
			
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end

GO

-- =============================================
-- SP_Product_Upd - ویرایش کالا
-- ثبت لاگ در ProductLog با ActionType = 'Update'
-- =============================================
create or alter  proc [dbo].[SP_Product_Upd]
@ProductID int,
@ProductName nvarchar(50),
@CategoryID int,
@BrandID int,
@UnitID int,
@Barcode nvarchar(60),
@Description nvarchar(100),
@IsActive bit
as begin
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from inv.Products where ProductID = @ProductID)
			begin
				select 'شناسه وارد شده وجود ندارد' as err
				rollback
				return
			end

			update inv.Products set ProductName = @ProductName ,CategoryID = @CategoryID 
			,BrandID = @BrandID ,UnitID = @UnitID ,Barcode = @Barcode ,Description = @Description ,IsActive = @IsActive
			where ProductID = @ProductID
		
			declare @ProductCode nvarchar(20) = (select ProductCode from inv.Products  where ProductID = @ProductID)
			insert into inv.ProductLog(ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,Description,IsActive,ActionType,CreateDate)
			values(@ProductID,@ProductCode,@ProductName,@CategoryID,@BrandID,@UnitID,@Barcode,@Description,default,'Update',getdate())

			select @ProductID as ProductID , 'محصول با موفقیت تغییر پیدا کرد' as status
			
		commit
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch
end

