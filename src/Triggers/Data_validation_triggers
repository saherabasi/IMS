-- =============================================
-- trg_Prevent_Duplicate_ProductCode - جلوگیری از ثبت کد محصول تکراری
-- =============================================
create trigger trg_Prevent_deplicate_ProductCode on inv.Products
after insert 
as begin
	set nocount on
	if exists (select 1 from inserted i inner join inv.Products p on i.ProductCode = p.ProductCode and i.ProductID != p.ProductID)
	begin
		select 'کد محصول تکراری است' as err
		rollback tran
	end
end
go

