-- =============================================
-- trg_Product_Audit - لاگ خودکار تغییرات محصولات
-- ثبت INSERT, UPDATE, DELETE در ProductLog
-- =============================================
create trigger trg_Product_Audit on inv.products 
after insert,update,delete 
as begin
	set nocount on

	if exists (select 1 from inserted) and not exists (select 1 from deleted)
	begin
		insert into inv.ProductLog(ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,
		Description,IsActive,ActionType,CreateDate)
		select ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,
		Description,IsActive,'Insert',GETDATE() from inserted 
	end

	if not exists (select 1 from inserted) and exists (select 1 from deleted)
	begin
		insert into inv.ProductLog(ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,
		Description,IsActive,ActionType,CreateDate)
		select ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,
		Description,IsActive,'Delete',GETDATE() from deleted 
	end

	if exists (select 1 from inserted) and exists (select 1 from deleted)
	begin
		insert into inv.ProductLog(ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,
		Description,IsActive,ActionType,CreateDate)
		select ProductID,ProductCode,ProductName,CategoryID,BrandID,UnitID,Barcode,
		Description,IsActive,'Update',GETDATE() from inserted 
	end
end
go

